<%# Close modal %>
<%= turbo_stream.update "modal", "" %>

<%# Refresh clients list %>
<%= turbo_stream.replace "clients_list" do %>
  <%= turbo_frame_tag "clients_list" do %>
    <% if @clients.empty? %>
      <%# Empty State %>
      <div class="bg-white rounded-xl border border-gray-200 px-6 py-15 text-center">
        <div class="w-14 h-14 rounded-xl bg-gray-100 mx-auto mb-4 flex items-center justify-center text-gray-400">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </div>
        <p class="text-base font-medium text-gray-700 mb-1.5">Sin clientes todavía</p>
        <p class="text-sm text-gray-400 mb-5">Crea tu primer cliente para empezar a generar propuestas</p>
        <%= link_to new_client_path, data: { turbo_frame: "modal" }, class: "inline-flex items-center gap-2 px-4 py-2 bg-[#1b5e3b] text-white rounded-lg text-sm font-medium hover:bg-[#2a7d54] transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Crear cliente
        <% end %>
      </div>
    <% else %>
      <%# Clients List %>
      <div style="display: flex; flex-direction: column; gap: 1px; background: #e5e7eb; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb;">
        <% @clients.each do |client| %>
          <%
            hue = (client.name&.chars&.first&.ord || 0) * 37 % 360
            bg_color = "hsl(#{hue}, 55%, 92%)"
            text_color = "hsl(#{hue}, 55%, 40%)"
            initials = client.name&.split(' ')&.map { |n| n[0] }&.join('')&.upcase&.slice(0, 2) || 'C'
          %>
          <div class="flex items-center gap-4 px-6 py-4 bg-white cursor-pointer hover:bg-gray-50 transition-colors" onclick="window.location='<%= client_path(client) %>'" style="cursor: pointer;">
            <%# Avatar %>
            <div class="w-11 h-11 rounded-xl flex items-center justify-center text-sm font-bold flex-shrink-0" style="background: <%= bg_color %>; color: <%= text_color %>;">
              <%= initials %>
            </div>

            <%# Info %>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-semibold text-gray-900 mb-0.5">
                <%= client.name %>
              </div>
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <% if client.company.present? %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                    <%= client.company %>
                  </span>
                <% end %>
                <% if client.email.present? %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <%= client.email %>
                  </span>
                <% end %>
                <% if client.phone.present? %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <%= client.phone %>
                  </span>
                <% end %>
              </div>
            </div>

            <%# Meta %>
            <div class="flex items-center gap-3 flex-shrink-0">
              <span class="text-xs font-medium text-gray-600 bg-gray-100 px-2.5 py-1 rounded">
                <%= client.try(:proposals_count) || 0 %> propuestas
              </span>
              <div class="flex gap-1" onclick="event.stopPropagation();">
                <%= link_to edit_client_path(client), data: { turbo_frame: "modal" }, class: "w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:bg-gray-100 hover:text-gray-700 transition-colors", title: "Editar" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                <% end %>
                <%= button_to client_path(client), method: :delete, form: { data: { turbo_confirm: "¿Seguro que quieres borrar este cliente?" } }, class: "w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:bg-red-50 hover:text-red-600 transition-colors", title: "Eliminar" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                <% end %>
              </div>
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>

<%# Show flash message %>
<%= turbo_stream.prepend "flash" do %>
  <div class="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded-lg shadow-lg max-w-md" style="animation: slideIn 0.3s ease-out;">
    <div class="flex items-center">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
      Cliente actualizado exitosamente.
    </div>
  </div>
<% end %>
