<div id="materials-list"
     data-controller="materials-filter audio-recorder"
     data-audio-recorder-upload-url-value="<%= upload_client_materials_path(client) %>">
  <%# ── Barra de acciones ──────────────────────────────────────────── %>
  <div class="flex flex-wrap gap-2 mb-4">
    <%# Subir archivo %>
    <label class="inline-flex items-center gap-2 px-4 py-2 bg-[#1b5e3b] text-white rounded-lg text-sm font-semibold cursor-pointer hover:bg-[#2a7d54] transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
      </svg>
      Subir archivo
      <%= form_with url: upload_client_materials_path(client), method: :post,
          data: { turbo: true },
          class: "hidden",
          id: "upload-form-#{client.id}" do |f| %>
        <%= f.file_field :file, accept: ".pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.mp3,.wav,.m4a,.ogg",
            class: "hidden",
            id: "file-input-#{client.id}",
            data: { action: "change->materials-filter#uploadFile",
                    "materials-filter-url-param": upload_client_materials_path(client) } %>
      <% end %>
      <input type="file"
             accept=".pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.mp3,.wav,.m4a,.ogg"
             class="hidden"
             data-materials-filter-target="fileInput"
             data-action="change->materials-filter#uploadFile"
             data-upload-url="<%= upload_client_materials_path(client) %>">
    </label>

    <%# Grabar audio (toggle del grabador de abajo) %>
    <button type="button"
            data-action="audio-recorder#toggle"
            data-audio-recorder-target="button"
            class="inline-flex items-center gap-2 px-4 py-2 bg-white text-gray-700 border border-gray-300 rounded-lg text-sm font-semibold hover:bg-gray-50 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
      </svg>
      Grabar audio
    </button>

    <%# Escribir nota %>
    <%= link_to new_client_material_path(client), data: { turbo_frame: "modal" },
        class: "inline-flex items-center gap-2 px-4 py-2 bg-amber-50 text-amber-700 border border-amber-200 rounded-lg text-sm font-semibold hover:bg-amber-100 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
      </svg>
      Escribir nota
    <% end %>

    <%# Importar de Drive %>
    <button type="button"
            data-controller="drive-import"
            data-drive-import-auth-url-value="/api/v1/drive/auth"
            data-drive-import-status-url-value="/api/v1/drive/status"
            data-drive-import-files-url-value="/api/v1/drive/files"
            data-drive-import-import-url-value="<%= "/api/v1/clients/#{client.id}/drive/import" %>"
            data-action="drive-import#open"
            class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-lg text-sm font-semibold hover:bg-emerald-100 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
      </svg>
      Importar de Drive
    </button>
  </div>

  <%# ── Grabador de audio (micrófono central) ──────────────────────────── %>
  <div class="flex flex-col items-center gap-2 py-6 mb-4 border border-dashed border-gray-200 rounded-xl bg-gray-50/50">
    <button type="button"
            data-action="audio-recorder#toggle"
            data-audio-recorder-target="button"
            aria-label="Grabar audio"
            class="w-16 h-16 rounded-full bg-[#1b5e3b] text-white flex items-center justify-center shadow-lg hover:bg-[#2a7d54] transition-colors">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
      </svg>
    </button>
    <span data-audio-recorder-target="timer" class="text-sm font-mono text-gray-500 tabular-nums">00:00</span>
    <span data-audio-recorder-target="status" class="text-sm text-gray-500">Pulsa para grabar una llamada o nota de voz</span>
  </div>

  <%# ── Progreso de subida ─────────────────────────────────────────── %>
  <div data-materials-filter-target="uploadProgress" class="hidden mb-4 p-3 bg-green-50 border border-green-200 rounded-lg">
    <div class="flex items-center gap-2 text-sm text-green-700">
      <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span data-materials-filter-target="uploadMessage">Subiendo archivo...</span>
    </div>
  </div>

  <% if materials.empty? %>
    <%# ── Estado vacío ───────────────────────────────────────────────── %>
    <div class="text-center py-12">
      <div class="w-16 h-16 bg-gray-100 rounded-full mx-auto mb-4 flex items-center justify-center">
        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <h3 class="text-base font-medium text-gray-900 mb-1">Sin materiales todavía</h3>
      <p class="text-sm text-gray-500">Sube documentos, notas o audios del cliente. La IA los usará para generar propuestas.</p>
    </div>
  <% else %>
    <%# ── Chips de filtro por tipo ───────────────────────────────────── %>
    <%
      type_colors = {
        'email'      => 'bg-blue-100 text-blue-700',
        'pdf'        => 'bg-red-100 text-red-700',
        'docx'       => 'bg-blue-100 text-blue-800',
        'xlsx'       => 'bg-green-100 text-green-700',
        'csv'        => 'bg-emerald-100 text-emerald-700',
        'txt'        => 'bg-gray-100 text-gray-600',
        'audio'      => 'bg-purple-100 text-purple-700',
        'transcript' => 'bg-violet-100 text-violet-700',
        'note'       => 'bg-amber-100 text-amber-700',
        'other'      => 'bg-gray-100 text-gray-600',
      }
      type_labels = {
        'email' => 'Email', 'pdf' => 'PDF', 'docx' => 'Word',
        'xlsx' => 'Excel', 'csv' => 'CSV', 'txt' => 'Texto',
        'audio' => 'Audio', 'transcript' => 'Transcripción',
        'note' => 'Nota', 'other' => 'Otro',
      }
      types_present = materials.map(&:material_type).tally
    %>
    <div class="flex flex-wrap gap-2 mb-4" data-materials-filter-target="filterBar">
      <button
        type="button"
        data-action="click->materials-filter#filterAll"
        data-materials-filter-target="allChip"
        class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-[#1b5e3b] text-white transition-colors">
        Todos
        <span class="bg-white/25 rounded-full px-1.5"><%= materials.size %></span>
      </button>
      <% types_present.each do |type, count| %>
        <button
          type="button"
          data-action="click->materials-filter#filterType"
          data-type="<%= type %>"
          data-materials-filter-target="typeChip"
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold <%= type_colors[type] || 'bg-gray-100 text-gray-600' %> transition-colors opacity-70 hover:opacity-100">
          <%= type_labels[type] || type.titleize %>
          <span class="bg-black/10 rounded-full px-1.5"><%= count %></span>
        </button>
      <% end %>
    </div>

    <%# ── Lista agrupada por tipo ────────────────────────────────────── %>
    <%
      type_order = %w[audio transcript email pdf docx xlsx csv txt note other]
      grouped = materials.group_by(&:material_type)
      audios = grouped['audio'] || []
      transcripts = grouped['transcript'] || []
    %>

    <%# Pares audio + transcripción %>
    <% if audios.any? %>
      <div class="mb-5" data-material-group="audio">
        <div class="flex items-center gap-2 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wide">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
          </svg>
          Audios y transcripciones
          <span class="bg-gray-100 rounded-full px-2 py-0.5 normal-case font-semibold text-gray-500"><%= audios.size + transcripts.size %></span>
        </div>
        <% audios.each do |audio| %>
          <%
            transcript = transcripts.find { |t| t.title&.include?(audio.title.to_s) || t.metadata&.dig('source') == 'audio' }
          %>
          <%= render 'clients/material_row', material: audio, client: client, badge: transcript ? 'Transcrito' : nil %>
        <% end %>
        <%# Transcripciones huérfanas %>
        <% transcripts.reject { |t| audios.any? { |a| t.title&.include?(a.title.to_s) } }.each do |t| %>
          <%= render 'clients/material_row', material: t, client: client %>
        <% end %>
      </div>
    <% end %>

    <%# Resto de tipos %>
    <% (type_order - ['audio', 'transcript']).each do |type| %>
      <% group = grouped[type] %>
      <% next unless group&.any? %>
      <div class="mb-5" data-material-group="<%= type %>">
        <div class="flex items-center gap-2 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wide">
          <span class="inline-block w-2 h-2 rounded-full <%= type_colors[type]&.split(' ')&.first || 'bg-gray-300' %>"></span>
          <%= type_labels[type] || type.titleize %>
          <span class="bg-gray-100 rounded-full px-2 py-0.5 normal-case font-semibold text-gray-500"><%= group.size %></span>
        </div>
        <% group.each do |material| %>
          <%= render 'clients/material_row', material: material, client: client %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
