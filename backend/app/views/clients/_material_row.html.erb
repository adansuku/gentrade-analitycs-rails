<%
  icon_bg = {
    'email' => 'bg-blue-50', 'pdf' => 'bg-red-50', 'docx' => 'bg-blue-50',
    'xlsx' => 'bg-green-50', 'csv' => 'bg-emerald-50', 'txt' => 'bg-gray-50',
    'audio' => 'bg-purple-50', 'transcript' => 'bg-violet-50',
    'note' => 'bg-amber-50', 'other' => 'bg-gray-50',
  }
  icon_color = {
    'email' => 'text-blue-500', 'pdf' => 'text-red-500', 'docx' => 'text-blue-600',
    'xlsx' => 'text-green-600', 'csv' => 'text-emerald-600', 'txt' => 'text-gray-500',
    'audio' => 'text-purple-600', 'transcript' => 'text-violet-600',
    'note' => 'text-amber-500', 'other' => 'text-gray-500',
  }
  mt = material.material_type
%>
<div class="group flex items-center gap-3 px-3 py-2.5 rounded-lg border border-transparent hover:bg-gray-50 hover:border-gray-200 transition-all cursor-pointer"
     data-material-type="<%= mt %>"
     data-action="click->materials-filter#openViewer"
     <%
       # Para audios con transcripción, el viewer muestra el texto transcrito;
       # si no, el contenido propio del material.
       viewer_content = if defined?(transcript) && transcript&.content.present?
                          transcript.content
                        else
                          material.content
                        end
     %>
     data-material-id="<%= material.id %>"
     data-material-title="<%= material.title.presence || material.material_type&.titleize %>"
     data-material-type-label="<%= mt&.titleize %>"
     data-material-content="<%= viewer_content&.truncate(5000) %>"
     <% if material.file.attached? %>
       data-material-file-url="<%= rails_blob_path(material.file, disposition: 'inline') %>"
       data-material-file-mime="<%= material.file.content_type %>"
     <% elsif material.file_url.present? %>
       data-material-file-url="<%= material.file_url %>"
     <% end %>>

  <%# Icono %>
  <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 <%= icon_bg[mt] || 'bg-gray-50' %> <%= icon_color[mt] || 'text-gray-500' %>">
    <% if %w[audio].include?(mt) %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
      </svg>
    <% elsif %w[note email transcript].include?(mt) %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
      </svg>
    <% else %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    <% end %>
  </div>

  <%# Info %>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2">
      <span class="text-sm font-medium text-gray-900 truncate">
        <%= material.title.presence || material.material_type&.titleize || 'Sin título' %>
      </span>
      <% if defined?(badge) && badge %>
        <span class="text-xs px-1.5 py-0.5 bg-green-100 text-green-700 rounded font-medium"><%= badge %></span>
      <% end %>
      <% if material.file.attached? %>
        <span class="text-xs px-1.5 py-0.5 bg-gray-100 text-gray-500 rounded">
          <%= number_to_human_size(material.metadata&.dig('size') || 0) %>
        </span>
      <% end %>
    </div>
    <span class="text-xs text-gray-400"><%= time_ago_in_words(material.created_at) %> atrás</span>
  </div>

  <%# Eliminar %>
  <%= button_to client_material_path(client, material), method: :delete,
      data: { turbo_confirm: "¿Eliminar «#{material.title.presence || material.material_type}»?" },
      class: "opacity-0 group-hover:opacity-100 transition-opacity p-1.5 text-gray-300 hover:text-red-500",
      form: { data: { turbo_frame: "_top" } } do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
    </svg>
  <% end %>
</div>
