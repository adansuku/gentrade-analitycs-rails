<%# Client Detail Screen %>
<div class="flex-1 overflow-auto bg-gray-50">
  <%# Header %>
  <div class="bg-white border-b border-gray-200 sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-6 py-4">
      <div class="flex items-center gap-4">
        <%# Back Button %>
        <%= link_to clients_path, class: "inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <span>Clientes</span>
        <% end %>

        <%# Client Info %>
        <div class="flex-1 min-w-0">
          <h1 class="text-lg font-semibold text-gray-900 truncate">
            <%= @client.name %>
          </h1>
          <% contact_parts = [@client.company, @client.email, @client.phone].compact %>
          <% if contact_parts.any? %>
            <p class="text-sm text-gray-500 truncate">
              <%= contact_parts.join(' · ') %>
            </p>
          <% end %>
        </div>

        <%# Edit Button %>
        <%= link_to edit_client_path(@client), data: { turbo_frame: "modal" }, class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          <span>Editar</span>
        <% end %>
      </div>
    </div>
  </div>

  <%# Content Area %>
  <div class="max-w-7xl mx-auto px-6 py-6">
    <%# Tabs %>
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden" data-controller="tabs" data-tabs-active-value="materials">
      <%# Tab Headers %>
      <div class="border-b border-gray-200 bg-gray-50">
        <nav class="flex gap-1 px-4">
          <button
            type="button"
            data-action="click->tabs#switch"
            data-tab="materials"
            data-tabs-target="tab"
            class="px-4 py-3 text-sm font-medium border-b-2 border-[#1b5e3b] text-[#1b5e3b]"
          >
            Materiales
            <span class="ml-2 px-2 py-0.5 text-xs bg-[#1b5e3b] text-white rounded-full">
              <%= @materials.count %>
            </span>
          </button>
          <button
            type="button"
            data-action="click->tabs#switch"
            data-tab="proposals"
            data-tabs-target="tab"
            class="px-4 py-3 text-sm font-medium text-gray-600 hover:text-gray-900 border-b-2 border-transparent hover:border-gray-300"
          >
            Propuestas
            <span class="ml-2 px-2 py-0.5 text-xs bg-gray-200 text-gray-700 rounded-full">
              <%= @proposals.count %>
            </span>
          </button>
        </nav>
      </div>

      <%# Tab Panels %>
      <div class="p-6">
        <%# Materials Tab %>
        <div data-tabs-target="panel" data-tab-panel="materials">
          <% if @materials.empty? %>
            <%# Empty State %>
            <div class="text-center py-12">
              <div class="w-16 h-16 bg-gray-100 rounded-full mx-auto mb-4 flex items-center justify-center">
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <h3 class="text-base font-medium text-gray-900 mb-2">Sin materiales todavía</h3>
              <p class="text-sm text-gray-500 mb-4">Los materiales son documentos, notas o archivos asociados a este cliente</p>
              <button type="button" class="inline-flex items-center gap-2 px-4 py-2 bg-[#1b5e3b] text-white rounded-lg text-sm font-medium hover:bg-[#2a7d54] transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Agregar material
              </button>
            </div>
          <% else %>
            <%# Materials List %>
            <div class="space-y-3">
              <% @materials.each do |material| %>
                <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-lg border border-gray-200 hover:border-gray-300 transition-colors">
                  <%# Icon %>
                  <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  </div>

                  <%# Content %>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-4">
                      <div class="flex-1">
                        <h4 class="text-sm font-medium text-gray-900 mb-1">
                          <%= material.title || 'Sin título' %>
                        </h4>
                        <% if material.content.present? %>
                          <p class="text-sm text-gray-600 line-clamp-2">
                            <%= truncate(material.content, length: 150) %>
                          </p>
                        <% end %>
                      </div>
                      <span class="text-xs text-gray-500 whitespace-nowrap">
                        <%= material.material_type&.titleize || 'Documento' %>
                      </span>
                    </div>
                    <div class="flex items-center gap-4 mt-2 text-xs text-gray-500">
                      <span><%= time_ago_in_words(material.created_at) %> atrás</span>
                      <% if material.file_url.present? %>
                        <span class="inline-flex items-center gap-1">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                          </svg>
                          Archivo adjunto
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <%# Proposals Tab %>
        <div data-tabs-target="panel" data-tab-panel="proposals" class="hidden">
          <% if @proposals.empty? %>
            <%# Empty State %>
            <div class="text-center py-12">
              <div class="w-16 h-16 bg-gray-100 rounded-full mx-auto mb-4 flex items-center justify-center">
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <h3 class="text-base font-medium text-gray-900 mb-2">Sin propuestas todavía</h3>
              <p class="text-sm text-gray-500 mb-4">Las propuestas son documentos generados automáticamente con IA</p>
              <button type="button" class="inline-flex items-center gap-2 px-4 py-2 bg-[#1b5e3b] text-white rounded-lg text-sm font-medium hover:bg-[#2a7d54] transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                Generar propuesta
              </button>
            </div>
          <% else %>
            <%# Proposals List %>
            <div class="space-y-3">
              <% @proposals.each do |proposal| %>
                <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-lg border border-gray-200 hover:border-gray-300 transition-colors cursor-pointer">
                  <%# Icon %>
                  <div class="w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  </div>

                  <%# Content %>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-4">
                      <div class="flex-1">
                        <h4 class="text-sm font-medium text-gray-900 mb-1">
                          Propuesta #<%= proposal.id %>
                        </h4>
                        <p class="text-sm text-gray-600">
                          <%= proposal.versions.count %> versión<%= proposal.versions.count != 1 ? 'es' : '' %>
                        </p>
                      </div>
                      <% status_colors = {
                        'draft' => 'bg-gray-100 text-gray-700',
                        'sent' => 'bg-blue-100 text-blue-700',
                        'accepted' => 'bg-green-100 text-green-700',
                        'rejected' => 'bg-red-100 text-red-700'
                      } %>
                      <span class="text-xs px-2 py-1 rounded <%= status_colors[proposal.status] || 'bg-gray-100 text-gray-700' %>">
                        <%= proposal.status&.titleize || 'Borrador' %>
                      </span>
                    </div>
                    <div class="flex items-center gap-4 mt-2 text-xs text-gray-500">
                      <span><%= time_ago_in_words(proposal.created_at) %> atrás</span>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Modal Placeholder %>
<%= turbo_frame_tag "modal" %>

<style>
.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style>
