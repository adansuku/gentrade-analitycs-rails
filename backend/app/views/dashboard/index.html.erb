<%# Dashboard Screen - Exact replica from React %>
<div class="flex-1 overflow-auto">
  <%# Hero Section %>
  <div style="background: linear-gradient(135deg, #1b5e3b 0%, #0f4a2a 50%, #0a2f1c 100%); padding: 40px 32px 48px; position: relative; overflow: hidden;">
    <%# Decorative circles %>
    <div style="position: absolute; top: -60px; right: -40px; width: 260px; height: 260px; border-radius: 50%; background: rgba(255,255,255,0.06);"></div>
    <div style="position: absolute; bottom: -80px; left: 30%; width: 200px; height: 200px; border-radius: 50%; background: rgba(255,255,255,0.04);"></div>

    <div style="max-width: 1100px; margin: 0 auto; position: relative; z-index: 1;">
      <div style="color: rgba(255,255,255,0.7); font-size: 0.8125rem; font-weight: 500; margin-bottom: 8px;">
        Panel comercial
      </div>
      <h1 style="color: #fff; font-size: 1.75rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 8px; line-height: 1.2;">
        Buenos días 👋
      </h1>
      <p style="color: rgba(255,255,255,0.65); font-size: 0.9375rem; margin-bottom: 28px; max-width: 480px;">
        Tienes <%= @totals[:proposals] %> propuestas activas y <%= @totals[:clients] %> clientes en seguimiento.
      </p>
      <div class="flex gap-2">
        <%= link_to("#", class: "inline-flex items-center gap-2 px-4 py-2 bg-white text-[#1b5e3b] rounded-lg font-semibold text-sm hover:bg-gray-50 transition-colors") do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Nueva propuesta
        <% end %>
        <%= link_to("#", class: "inline-flex items-center gap-2 px-4 py-2 text-white border border-white/20 rounded-lg font-medium text-sm hover:bg-white/10 transition-colors") do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
          </svg>
          Ver pipeline
        <% end %>
      </div>
    </div>
  </div>

  <%# Stats Bar - overlapping hero %>
  <div style="max-width: 1100px; margin: -24px auto 0; padding: 0 32px; position: relative; z-index: 2;">
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #e5e7eb; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
      <%# Stat 1: Clientes %>
      <div class="bg-white p-5 flex items-center gap-4">
        <div class="w-11 h-11 rounded-lg bg-[#1b5e3b10] text-[#1b5e3b] flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </div>
        <div>
          <div class="text-2xl font-bold leading-tight" style="letter-spacing: -0.03em; font-variant-numeric: tabular-nums;">
            <%= @totals[:clients] %>
          </div>
          <div class="text-xs text-gray-500 font-medium mt-0.5">Clientes</div>
        </div>
      </div>

      <%# Stat 2: Propuestas %>
      <div class="bg-white p-5 flex items-center gap-4">
        <div class="w-11 h-11 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div>
          <div class="text-2xl font-bold leading-tight" style="letter-spacing: -0.03em; font-variant-numeric: tabular-nums;">
            <%= @totals[:proposals] %>
          </div>
          <div class="text-xs text-gray-500 font-medium mt-0.5">Propuestas</div>
        </div>
      </div>

      <%# Stat 3: Materiales %>
      <div class="bg-white p-5 flex items-center gap-4">
        <div class="w-11 h-11 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
        </div>
        <div>
          <div class="text-2xl font-bold leading-tight" style="letter-spacing: -0.03em; font-variant-numeric: tabular-nums;">
            <%= @totals[:materials] %>
          </div>
          <div class="text-xs text-gray-500 font-medium mt-0.5">Materiales</div>
        </div>
      </div>

      <%# Stat 4: Este mes %>
      <div class="bg-white p-5 flex items-center gap-4">
        <div class="w-11 h-11 rounded-lg bg-[#2a7d5410] text-[#2a7d54] flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <div>
          <div class="text-2xl font-bold leading-tight" style="letter-spacing: -0.03em; font-variant-numeric: tabular-nums;">
            <%= @totals[:proposals_this_month] %>
          </div>
          <div class="text-xs text-gray-500 font-medium mt-0.5">Este mes</div>
        </div>
      </div>
    </div>
  </div>

  <%# Main Content: 2 columns %>
  <div style="max-width: 1100px; margin: 0 auto; padding: 32px 32px 48px; display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start;">
    <%# Left: Priority Clients %>
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
        <div>
          <h2 class="text-base font-semibold mb-0.5">Clientes prioritarios</h2>
          <p class="text-xs text-gray-500">Ordenados por sentimiento</p>
        </div>
        <%= link_to("#", class: "text-sm font-medium text-[#1b5e3b] hover:text-[#2a7d54]") do %>
          Ver todos →
        <% end %>
      </div>

      <% if @priority_clients.any? %>
        <div>
          <% @priority_clients.each_with_index do |client, index| %>
            <%= link_to("#", class: "flex items-center justify-between px-6 py-3.5 hover:bg-gray-50 transition-colors #{index < @priority_clients.size - 1 ? 'border-b border-gray-50' : ''}") do %>
              <div class="flex items-center gap-3.5">
                <% 
                  hue = (client.name&.chars&.first&.ord || 0) * 37 % 360
                  bg_color = "hsl(#{hue}, 55%, 92%)"
                  text_color = "hsl(#{hue}, 55%, 40%)"
                %>
                <div class="w-9 h-9 rounded-lg flex items-center justify-center text-xs font-bold flex-shrink-0" style="background: <%= bg_color %>; color: <%= text_color %>;">
                  <%= client.name&.first&.upcase || 'C' %>
                </div>
                <div>
                  <div class="text-sm font-medium text-gray-900"><%= client.name %></div>
                  <div class="text-xs text-gray-400"><%= client.email %></div>
                </div>
              </div>
              <div class="flex items-center gap-2.5">
                <span class="text-xs text-gray-600 font-medium bg-gray-100 px-2 py-0.5 rounded">
                  <%= client.try(:proposals_count) || 0 %> prop.
                </span>
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-15 text-center text-gray-400">
          <div class="w-14 h-14 rounded-xl bg-gray-100 mx-auto mb-4 flex items-center justify-center">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <p class="text-sm font-medium text-gray-700 mb-1.5">Sin clientes todavía</p>
          <p class="text-xs mb-5">Crea tu primer cliente para empezar a generar propuestas</p>
          <%= link_to("#", class: "inline-flex items-center gap-2 px-4 py-2 bg-[#1b5e3b] text-white rounded-lg text-sm font-medium hover:bg-[#2a7d54] transition-colors") do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Crear cliente
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Right: Sidebar %>
    <div class="flex flex-col gap-4">
      <%# Quick Actions %>
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100">
          <h3 class="text-sm font-semibold">Accesos directos</h3>
        </div>
        <div class="p-2">
          <% [
            { icon: 'users', label: 'Clientes', desc: 'Gestionar base de clientes', path: '#' },
            { icon: 'columns', label: 'Pipeline', desc: 'Embudo de ventas', path: '#' },
            { icon: 'package', label: 'Productos', desc: 'Catálogo de servicios', path: '#' },
            { icon: 'activity', label: 'Métricas', desc: 'Rendimiento comercial', path: '#' }
          ].each do |item| %>
            <%= link_to(item[:path], class: "flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-50 transition-colors") do %>
              <div class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center text-gray-600 flex-shrink-0">
                <% case item[:icon] %>
                <% when 'users' %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                <% when 'columns' %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
                  </svg>
                <% when 'package' %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                  </svg>
                <% when 'activity' %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                  </svg>
                <% end %>
              </div>
              <div>
                <div class="text-xs font-medium"><%= item[:label] %></div>
                <div class="text-[0.6875rem] text-gray-400"><%= item[:desc] %></div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Needs Attention %>
      <% if @needs_attention.any? %>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-red-600 animate-pulse"></div>
            <h3 class="text-sm font-semibold">Necesitan atención</h3>
            <span class="ml-auto text-xs font-semibold bg-red-50 text-red-600 px-2 py-0.5 rounded-full">
              <%= @needs_attention.count %>
            </span>
          </div>
          <div class="p-2">
            <% @needs_attention.each do |client| %>
              <%= link_to("#", class: "flex items-center gap-2.5 px-3 py-2 rounded-lg hover:bg-red-50 transition-colors text-xs") do %>
                <span class="w-1.5 h-1.5 rounded-full bg-red-600 flex-shrink-0"></span>
                <span class="font-medium"><%= client.name %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Recent Activity %>
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100">
          <h3 class="text-sm font-semibold">Actividad reciente</h3>
        </div>
        <div class="px-5 py-6 text-center text-gray-400">
          <p class="text-xs">Las acciones recientes aparecerán aquí</p>
        </div>
      </div>
    </div>
  </div>
</div>
