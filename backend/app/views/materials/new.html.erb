<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50" id="material-modal">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4">
      <%# Header %>
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Añadir material</h2>
        <%= link_to client_path(@client), data: { turbo_frame: "modal" }, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>

      <%# Form %>
      <%= form_with model: [@client, @material], class: "px-6 py-4 space-y-4" do |f| %>
        <% if @material.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-3">
            <ul class="text-sm text-red-600 space-y-1">
              <% @material.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%# Título %>
        <div>
          <%= f.label :title, "Título", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :title, placeholder: "Ej: Acuerdo de colaboración, Notas de reunión...",
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#1b5e3b] focus:border-transparent" %>
        </div>

        <%# Tipo %>
        <div>
          <%= f.label :material_type, "Tipo", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :material_type,
              [["Nota", "note"], ["Email", "email"], ["PDF", "pdf"], ["Documento Word", "docx"],
               ["Hoja de cálculo", "xlsx"], ["CSV", "csv"], ["Audio", "audio"], ["Transcripción", "transcript"], ["Otro", "other"]],
              {},
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#1b5e3b] focus:border-transparent" %>
        </div>

        <%# Contenido %>
        <div>
          <%= f.label :content, "Contenido", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :content, rows: 5, placeholder: "Escribe el contenido del material aquí...",
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#1b5e3b] focus:border-transparent resize-none" %>
        </div>

        <%# Footer %>
        <div class="flex items-center justify-end gap-3 pt-2 border-t border-gray-200">
          <%= link_to "Cancelar", client_path(@client), data: { turbo_frame: "modal" },
              class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
          <%= f.submit "Guardar material",
              class: "px-4 py-2 text-sm font-medium text-white bg-[#1b5e3b] rounded-lg hover:bg-[#2a7d54] transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
