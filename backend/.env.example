# ═══════════════════════════════════════════════════════════════════════
# GENTRADE Analytics — Rails Backend Variables
# ═══════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════
# SERVIDOR
# ═══════════════════════════════════════════════════════════════════════
RAILS_ENV=development
PORT=3002
APP_URL=http://localhost:3002

# ═══════════════════════════════════════════════════════════════════════
# BASE DE DATOS
# ═══════════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/gentrade_rails_development
POSTGRES_PASSWORD=postgres

# ═══════════════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6380/0

# ═══════════════════════════════════════════════════════════════════════
# AUTH — JWT
# ═══════════════════════════════════════════════════════════════════════
JWT_SECRET=cambia-esto-por-un-secreto-aleatorio-muy-largo
JWT_EXPIRATION=86400
OAUTH_STATE_SECRET=cambia-esto-oauth-state-secreto-separado-del-jwt-dev-local

# ═══════════════════════════════════════════════════════════════════════
# FRONTEND
# ═══════════════════════════════════════════════════════════════════════
FRONTEND_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════════════
# LLM — AI Integration (OpenAI compatible)
# ═══════════════════════════════════════════════════════════════════════
# OpenRouter (uses OpenAI SDK)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# LLM Models
LLM_MODEL=anthropic/claude-3.5-sonnet
LLM_MODEL_FAST=anthropic/claude-3-haiku
LLM_MAX_TOKENS=3000
LLM_TEMPERATURE=0.7

# General Chat
GENERAL_CHAT_MODEL=anthropic/claude-3-haiku
GENERAL_CHAT_MAX_TOKENS=800

# ═══════════════════════════════════════════════════════════════════════
# EMAIL — Brevo (Sendinblue)
# ═══════════════════════════════════════════════════════════════════════
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SMTP_USER=your-brevo-smtp-login-here
EMAIL_FROM=your-email@example.com

# ═══════════════════════════════════════════════════════════════════════
# INTEGRACIONES — Cifrado y sync
# ═══════════════════════════════════════════════════════════════════════
ENCRYPTION_KEY=gentrade-secret-key-production-2024
SYNC_CRON=0 6 * * *

# ═══════════════════════════════════════════════════════════════════════
# GOOGLE — OAuth para Google Drive y Analytics/Ads
# ═══════════════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_INTEGRATIONS_REDIRECT_URI=http://localhost:3002/api/integrations/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3002/api/drive/callback
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token-here

# ═══════════════════════════════════════════════════════════════════════
# META — Facebook/Instagram OAuth
# ═══════════════════════════════════════════════════════════════════════
META_APP_ID=your-meta-app-id-here
META_APP_SECRET=your-meta-app-secret-here
META_REDIRECT_URI=http://localhost:3002/api/integrations/meta/callback

# ═══════════════════════════════════════════════════════════════════════
# SLACK — OAuth para reportes y notificaciones
# ═══════════════════════════════════════════════════════════════════════
SLACK_CLIENT_ID=your-slack-client-id-here
SLACK_CLIENT_SECRET=your-slack-client-secret-here
SLACK_REDIRECT_URI=http://localhost:3002/api/v1/integrations/slack/callback
SLACK_SCOPES=chat:write,channels:read,chat:write.public

# ═══════════════════════════════════════════════════════════════════════
# SHOPIFY — OAuth para e-commerce
# ═══════════════════════════════════════════════════════════════════════
SHOPIFY_CLIENT_ID=your-shopify-client-id-here
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret-here
SHOPIFY_REDIRECT_URI=http://localhost:3002/api/integrations/shopify/callback
SHOPIFY_SCOPES=read_products,read_inventory,read_orders,read_analytics,read_reports
